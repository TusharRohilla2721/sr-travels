# ─────────────────────────────────────────────────────────
# SR Travels — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it is in .gitignore already.
# ─────────────────────────────────────────────────────────

# Supabase (get from https://app.supabase.com → Project → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# NEVER put SUPABASE_SERVICE_ROLE_KEY here.
# It only lives inside Supabase Edge Function Secrets.

# WhatsApp Business number (digits only, with country code, no + sign)
VITE_WHATSAPP_NUMBER=91XXXXXXXXXX
